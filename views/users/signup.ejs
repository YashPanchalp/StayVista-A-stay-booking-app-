<%- layout("/layouts/boilerplate") %>

<section class="form-page auth-page container py-5">
    <div class="form-page__intro auth-page__intro">
        <div>
            <span class="eyebrow eyebrow--light"><i class="bi bi-person-plus-fill"></i> Create account</span>
            <h1>Sign up for StayVista</h1>
            <p>Create your account to save favorites, leave reviews, and start hosting.</p>
        </div>
    </div>

    <div class="auth-card form-shell">
        <form action="/signup" method="POST" class="listing-form auth-form">
            <div class="form-grid auth-form__grid">
                <label class="field field--wide" for="username">
                    <span>Username</span>
                    <input
                        name="username"
                        id="username"
                        type="text"
                        placeholder="Choose a username"
                        required>
                </label>

                <label class="field field--wide" for="email">
                    <span>Email</span>
                    <input
                        name="email"
                        id="email"
                        type="email"
                        placeholder="Enter your email address"
                        required>
                </label>

                <label class="field field--wide" for="password">
                    <span>Password</span>
                    <input
                        name="password"
                        id="password"
                        type="password"
                        placeholder="Create a password"
                        required>
                </label>
            </div>

            <div class="form-actions auth-form__actions">
                <a href="/login" class="btn btn-outline-secondary">Already have an account?</a>
                <button class="btn btn-dark auth-submit">Sign Up</button>
            </div>
        </form>
    </div>
</section>