<%- layout("/layouts/boilerplate") %>

<div>
    <form action="/signup" method="POST">

        <h1>Signup on StayVista</h1>
        <label for="username">UserName: </label><input
        name = "username"
        id = "username"
        type = 'text'
        required>

        <label for="">Email: </label><input
        name = "email"
        id = "email"
        type = 'email'
        required>

        <label for="">Password: </label><input
        name = "password"
        id = "password"
        type = 'password'
        required>

        <button>Sign Up</button>

    </form>
</div>