<%- layout("/layouts/boilerplate") %>

<div>
    <form action="/login" method="POST">

        <h1>Login on StayVista</h1>
        <label for="username">UserName: </label><input
        name = "username"
        id = "username"
        type = 'text'
        required>

        <label for="">Password: </label><input
        name = "password"
        id = "password"
        type = 'password'
        required>

        <button>Login</button>

    </form>
</div>