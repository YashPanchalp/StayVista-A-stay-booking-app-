<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>wanderlust</title>
</head>
<body>

    <h3>Create a new Listing</h3>
    
    <form method="post" action="/listings">

        Title : <input name="listing[title]" placeholder="enter the title" type="text">
        <br><br>

        Description : <textarea name="listing[description]" placeholder="enter the desc" type="text"></textarea>
        <br><br>

        Image url : <input name="listing[image]" placeholder="enter the image URL/link" type="text">
        <br><br>

        Price : <input name="listing[price]" placeholder="enter the price" type="number">
        <br><br>

        Country: <input name="listing[country]" placeholder="enter the country" type="text">
        <br><br>

        Location : <input name="listing[location]" placeholder="enter the location" type="text">
        <br><br>

        <button>Add</button>

    </form>
</body>
</html>