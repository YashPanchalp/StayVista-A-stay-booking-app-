<%- layout("/layouts/boilerplate") %>

<section class="form-page container py-5">
    <div class="form-page__intro">
        <span class="eyebrow"><i class="bi bi-sliders"></i> Edit listing</span>
        <h1>Refine the listing</h1>
        <p>Update the stay details while keeping the same polished StayVista presentation.</p>
    </div>

    <div class="form-shell">
        <form method="post" action="/listings/<%= listing._id %>?_method=PUT" class="listing-form">
            <div class="form-grid">
                <label class="field">
                    <span>Title</span>
                    <input name="listing[title]" value="<%= listing.title %>" type="text" required>
                </label>

                <label class="field field--wide">
                    <span>Description</span>
                    <textarea name="listing[description]" rows="5"><%= listing.description %></textarea>
                </label>

                <label class="field field--wide">
                    <span>Image URL</span>
                    <input name="listing[image][url]" value="<%= listing.image && listing.image.url ? listing.image.url : '' %>" type="text" required>
                </label>

                <label class="field">
                    <span>Price</span>
                    <input name="listing[price]" value="<%= listing.price %>" type="number" min="0" required>
                </label>

                <label class="field">
                    <span>Country</span>
                    <input name="listing[country]" value="<%= listing.country %>" type="text" required>
                </label>

                <label class="field field--wide">
                    <span>Location</span>
                    <input name="listing[location]" value="<%= listing.location %>" type="text" required>
                </label>
            </div>

            <div class="form-actions">
                <a href="/listings/<%= listing._id %>" class="btn btn-ghost">Back</a>
                <button class="btn btn-accent" type="submit">Save Changes</button>
            </div>
        </form>
    </div>
</section>