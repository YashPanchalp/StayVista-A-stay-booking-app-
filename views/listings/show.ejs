<%- layout("/layouts/boilerplate") %>

<section class="detail-page container py-5">
    <div class="detail-layout">
        <div class="detail-media">
            <img src="<%= listing.image && listing.image.url ? listing.image.url : '' %>" alt="<%= listing.title %>">
        </div>

        <div class="detail-panel">
            <span class="eyebrow"><i class="bi bi-award"></i> Featured stay</span>
            <h1><%= listing.title %></h1>
            <p class="detail-panel__description"><%= listing.description %></p>

            <div class="detail-price">&#8377; <%= Number(listing.price || 0).toLocaleString("en-IN") %> <span>/ night</span></div>

            <div class="detail-meta">
                <div>
                    <span>Location</span>
                    <strong><%= listing.location %></strong>
                </div>
                <div>
                    <span>Country</span>
                    <strong><%= listing.country %></strong>
                </div>
            </div>

            <div class="detail-actions">
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-accent">
                    <i class="bi bi-pencil-square"></i>
                    Edit Listing
                </a>
                <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
                    <button class="btn btn-ghost btn-ghost--danger" type="submit">
                        <i class="bi bi-trash3"></i>
                        Delete Listing
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Review Section -->
    <div class="reviews-section mt-5 pt-4 border-top">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <h4 class="mb-4">Leave a Review</h4>
                <div class="card p-4 shadow-sm border-0 bg-white rounded-4 mb-5">
                    <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Rating</label>
                            <div class="star-rating d-inline-flex">
                                <input type="radio" id="star5" name="review[rating]" value="5" />
                                <label for="star5" title="5 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star4" name="review[rating]" value="4" />
                                <label for="star4" title="4 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star3" name="review[rating]" value="3" />
                                <label for="star3" title="3 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star2" name="review[rating]" value="2" />
                                <label for="star2" title="2 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star1" name="review[rating]" value="1" checked />
                                <label for="star1" title="1 star"><i class="bi bi-star-fill"></i></label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="comment" class="form-label fw-semibold">Share your experience</label>
                            <textarea name="review[comment]" class="form-control bg-light border-0" id="comment" cols="30" rows="4" placeholder="How was your stay?" required></textarea>
                            <div class="invalid-feedback">Please add some comments for your review.</div>
                            <div class="valid-feedback">Looks good!</div>
                        </div>
                        
                        <button class="btn btn-dark w-100 py-2 fw-semibold rounded-3">Submit Review</button>  
                    </form>
                </div>

                <% if (listing.reviews && listing.reviews.length > 0) { %>
                    <hr class="my-5" />
                    <h4 class="mb-4">All Reviews</h4>
                    <div class="row row-cols-1 row-cols-md-2 g-4">
                        <% for(review of listing.reviews) { %>
                            <div class="col">
                                <div class="card p-4 shadow-sm border-0 h-100 rounded-4">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="mb-0 fw-bold">Guest User</h6>
                                        <div class="text-warning">
                                            <% for(let i=1; i<=5; i++) { %>
                                                <% if(i <= review.rating) { %>
                                                    <i class="bi bi-star-fill"></i>
                                                <% } else { %>
                                                    <i class="bi bi-star"></i>
                                                <% } %>
                                            <% } %>
                                        </div>
                                    </div>
                                    <p class="card-text text-muted mb-0 small"><%= review.comment %></p>
                                    <br>
                                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                                        <button>Delete</button>
                                    </form>
                                </div>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</section>
